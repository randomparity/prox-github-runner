{{ ansible_managed | comment }}
# Runner .env for svc-{{ item }} (loaded by the Actions runner at start).
# The job hooks write/remove a per-service active-job marker keyed by runner
# name; the completed hook also triggers the age-gated workspace cleanup.
ACTIONS_RUNNER_HOOK_JOB_STARTED={{ github_runner_hook_started }}
ACTIONS_RUNNER_HOOK_JOB_COMPLETED={{ github_runner_hook_completed }}
PROX_RUNNER_JOB_MARKER={{ github_runner_jobs_dir }}/{{ github_runner_name_prefix }}-{{ item }}
PROX_RUNNER_CLEANUP={{ github_runner_cleanup_script }}
