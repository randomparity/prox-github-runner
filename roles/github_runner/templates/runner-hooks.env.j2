{{ ansible_managed | comment }}
# Runner .env for svc-{{ item }} (loaded by the Actions runner at start and
# injected into every job's environment).
#
# The job hooks write/remove a per-service active-job marker keyed by runner
# name; the completed hook also triggers the age-gated workspace cleanup.
ACTIONS_RUNNER_HOOK_JOB_STARTED={{ github_runner_hook_started }}
ACTIONS_RUNNER_HOOK_JOB_COMPLETED={{ github_runner_hook_completed }}
PROX_RUNNER_JOB_MARKER={{ github_runner_jobs_dir }}/{{ github_runner_name_prefix }}-{{ item }}
PROX_RUNNER_CLEANUP={{ github_runner_cleanup_script }}
#
# Per-service toolchain isolation. RUSTUP_HOME and RUNNER_TOOL_CACHE are
# per-service so concurrent `rustup toolchain install` / `actions/setup-python`
# runs across the {{ github_runner_count | default('N') }} services never race a
# shared store (the rustc-vanishing / stale-target failures). The cargo registry
# stays shared (CARGO_HOME) for cache reuse — cargo's own package-cache lock makes
# concurrent access safe. These MUST live here (the job-injected .env), not in an
# unwired EnvironmentFile, or the isolation never reaches the job.
RUSTUP_HOME={{ github_runner_install_root }}/svc-{{ item }}/rustup
RUNNER_TOOL_CACHE={{ github_runner_install_root }}/svc-{{ item }}/_tool
CARGO_HOME={{ github_runner_home }}/.cargo
