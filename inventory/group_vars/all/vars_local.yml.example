---
# Copy this file to vars_local.yml (which is gitignored) and set your site's
# real values. vars_local.yml is loaded after vars.yml, so the keys here
# override the placeholders there. Only include the keys you need to change.
runner_vm_id: 99
runner_vm_name: "linux-runner"
runner_vm_ip: "10.0.0.99"
runner_vm_gateway: "10.0.0.1"
runner_vm_nameserver: "10.0.0.1"
runner_vm_searchdomain: "example.lan"
